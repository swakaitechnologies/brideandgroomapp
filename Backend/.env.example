# ==========================================
# BRIDE&GROOM PRODUCTION ENV TEMPLATE
# ==========================================

# --- Platform Branding ---
PLATFORM_NAME="Bride&Groom"
LOGO_URL=https://brideandgroom.co.in/Logo.png

# --- Server Configuration ---
PORT=5000
NODE_ENV=production
ALLOWED_ORIGINS=https://brideandgroom.co.in,http://localhost:5173
SENTRY_DSN=
# Limit for request body size (e.g. for image uploads)
MAX_BODY_SIZE=10mb

# --- Database (Sequelize with Read Replicas) ---
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=matrimony
DB_PORT=3306
# High-availability read replicas
DB_READ_HOST=localhost

# --- Redis (Caching & Rate Limiting) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Security & Auth ---
JWT_SECRET=generate_a_strong_random_string_here
REFRESH_TOKEN_SECRET=generate_another_strong_random_string_here
# Used for encrypting sensitive data in DB if needed
ENCRYPTION_KEY=32_character_hex_string_here
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# --- MinIO (Object Storage) ---
# For production, use a public domain or S3 compatible service
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=matrimony-uploads
MINIO_KYC_BUCKET=kyc-documents
# Public URL for frontend image loading
MINIO_PUBLIC_URL=http://localhost:9000

# --- Payment Gateways ---
# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Email (SMTP) ---
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="Bride&Groom <noreply@brideandgroom.co.in>"

# --- Monitoring & Observability ---
GRAFANA_ADMIN_PASSWORD=admin
# Prometheus metrics are exposed at /api/metrics
PROMETHEUS_ENABLED=true

# --- Rate Limiting ---
AUTH_RATE_LIMIT_WINDOW=15
AUTH_RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_MAX=10
